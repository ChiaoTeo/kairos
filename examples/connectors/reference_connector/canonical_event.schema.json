{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kairospy://contracts/canonical-market-event-v1",
  "title": "Kairos Canonical Market Event v1",
  "type": "object",
  "required": [
    "message_id", "schema_id", "schema_version", "kind", "instrument_id", "payload",
    "source", "source_instance", "stream_id", "partition_key", "event_time",
    "receive_time", "available_time", "published_time", "canonical_sequence", "flags"
  ],
  "properties": {
    "message_id": {"type": "object", "required": ["$uuid"]},
    "schema_id": {"type": "string"},
    "schema_version": {"type": "integer", "minimum": 1},
    "kind": {"type": "string"},
    "instrument_id": {"type": "object", "required": ["value"]},
    "payload": {"type": "object"},
    "source": {"type": "string"},
    "source_instance": {"type": "string"},
    "stream_id": {"type": "string"},
    "partition_key": {"type": "string"},
    "source_sequence": {"type": ["integer", "null"]},
    "receive_sequence": {"type": ["integer", "null"]},
    "canonical_sequence": {"type": "integer", "minimum": 0},
    "capture_offset": {"type": ["string", "null"]},
    "event_time": {"type": "object", "required": ["$datetime"]},
    "receive_time": {"type": "object", "required": ["$datetime"]},
    "available_time": {"type": "object", "required": ["$datetime"]},
    "published_time": {"type": "object", "required": ["$datetime"]},
    "flags": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": true
}
