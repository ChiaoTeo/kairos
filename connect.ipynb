   "source": [
    "from ib_async import *\n",
    "\n",
    "ib = IB()\n",
    "ib.connect('127.0.0.1', 7497, clientId=1)\n",
    "\n",
    "# Get account summary\n",
    "account = ib.managedAccounts()[0]\n",
    "summary = ib.accountSummary(account)\n",
    "for item in summary:\n",
    "    print(f\"{item.tag}: {item.value}\")\n",
    "\n",
    "ib.disconnect()"
